{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CI: jekyll build",
      "type": "shell",
      "command": "bundle exec jekyll build --trace",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "JEKYLL_ENV": "production"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "npm install",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
